{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "short_name": "TextHumanize",
  "description": "__MSG_extDesc__",
  "version": "2.1.0",
  "default_locale": "en",
  "author": "Alexandr Krikun",
  "homepage_url": "https://github.com/ksanyok/TextHumanize",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TextHumanize",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/shared.js",
        "content/panel.js",
        "content/editors.js",
        "content/images.js",
        "content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "permissions": ["contextMenus", "storage", "activeTab", "scripting"],
  "optional_permissions": ["clipboardWrite"],
  "optional_host_permissions": ["<all_urls>"],
  "commands": {
    "humanize-selection": {
      "suggested_key": { "default": "Ctrl+Shift+H", "mac": "Command+Shift+H" },
      "description": "__MSG_cmdHumanizeSelection__"
    },
    "check-selection": {
      "suggested_key": { "default": "Ctrl+Shift+U", "mac": "Command+Shift+U" },
      "description": "__MSG_cmdCheckSelection__"
    }
  }
}
